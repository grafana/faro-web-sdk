{
  "name": "faro-web-sdk",
  "version": "2.7.1",
  "description": "Monorepo for Faro Web SDK",
  "license": "Apache-2.0",
  "author": "Grafana Labs",
  "homepage": "https://github.com/grafana/faro-web-sdk#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/grafana/faro-web-sdk.git"
  },
  "private": true,
  "workspaces": [
    "packages/**",
    "experimental/**",
    "e2e/*"
  ],
  "main": "index.js",
  "scripts": {
    "start": "lerna run --parallel start",
    "watch": "lerna run --parallel watch",
    "bootstrap": "lerna bootstrap",
    "build": "lerna run build",
    "prepublish": "yarn build",
    "clean": "run-s 'clean:*'",
    "clean:packages": "lerna run --parallel clean",
    "clean:root": "rimraf .cache yarn-error.log",
    "quality": "run-p quality:circular-deps quality:test quality:lint quality:e2e:smoke:ci",
    "quality:packages": "lerna run --parallel quality",
    "quality:test": "lerna run --parallel quality:test",
    "quality:e2e:smoke:ci": "yarn workspace @grafana/faro-smoke-harness run e2e:ci",
    "quality:format": "run-p quality:format:*",
    "quality:format:root": "prettier --cache --cache-location=.cache/prettier/root -w \"./**/*.{js,jsx,ts,tsx,css,scss,md,yaml,yml,json}\"",
    "quality:format:packages": "lerna run --parallel quality:format",
    "quality:lint": "run-s quality:lint:packages quality:lint:root",
    "quality:lint:packages": "lerna run --parallel quality:lint",
    "quality:lint:root": "run-p 'quality:lint:root:*'",
    "quality:lint:root:markdown": "markdownlint README.md docs/**/*.md",
    "quality:lint:root:prettier": "prettier --cache --cache-location=.cache/prettier/root -c \"./**/*.{js,jsx,ts,tsx,css,scss,md,yaml,yml,json}\" \"!./packages/**\"",
    "quality:lint:fix": "run-p quality:lint:fix:root quality:lint:fix:packages",
    "quality:lint:fix:root": "prettier --cache --cache-location=.cache/prettier/root -w \"./**/*.{js,jsx,ts,tsx,css,scss,md,yaml,yml,json}\" \"!./{packages,experimental}/**\"",
    "quality:lint:fix:packages": "lerna run --parallel quality:lint:fix",
    "quality:circular-deps": "lerna run --parallel quality:circular-deps",
    "publish": "lerna publish",
    "git-hooks": "run-s git-hooks:*",
    "git-hooks:pre-commit": "lint-staged",
    "drone": "run-s drone:lint drone:sign",
    "drone:lint": "drone lint .drone/drone.yml --trusted",
    "drone:sign": "drone --server https://drone.grafana.net sign --save grafana/faro-web-sdk .drone/drone.yml"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@grafana/eslint-config": "10.0.0",
    "@rollup/plugin-commonjs": "29.0.3",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@types/jest": "30.0.0",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "63.0.7",
    "eslint-plugin-no-only-tests": "3.4.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "lerna": "9.0.7",
    "lint-staged": "17.0.8",
    "madge": "8.0.0",
    "markdownlint-cli": "0.49.0",
    "npm-run-all2": "9.0.2",
    "prettier": "3.8.4",
    "rimraf": "6.1.3",
    "rollup": "4.62.2",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  },
  "packageManager": "yarn@4.17.0",
  "resolutions": {
    "tough-cookie": "^6.0.0",
    "cross-spawn": "^7.0.0",
    "jsdom@npm:^26.1.0": "patch:jsdom@npm%3A26.1.0#~/.yarn/patches/jsdom-npm-26.1.0-3857255f02.patch",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "systeminformation": "^5.31.0",
    "@isaacs/brace-expansion": "^5.0.1",
    "protobufjs": "^8.0.1",
    "tar": "^7.5.8",
    "axios": "^1.15.2",
    "uuid": "^14.0.0",
    "tmp": "^0.2.6"
  }
}
